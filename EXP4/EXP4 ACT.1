# A teacher stores marks of students in a list fins average and topper marks 
"""
Created on Mon Mar 16 16:01:58 2026

@author: Imrose
"""

# List storing marks of students
marks = [75, 82, 90, 68, 88]

# Calculate average marks
average = sum(marks) / len(marks)

# Find topper marks
topper = max(marks)

# Display results
print("Marks of students:", marks)
print("Average Marks:", average)
print("Topper Marks:", topper)
