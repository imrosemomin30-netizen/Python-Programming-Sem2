@author: imrose
"""

# Function to read and display complaints
def read_complaints():
    try:
        file = open("complaints.txt", "r")
        print("\n--- Complaint Records ---\n")
        
        content = file.read()
        if content == "":
            print("No complaints found.")
        else:
            print(content)
        
        file.close()
    
    except FileNotFoundError:
        print("Complaint file not found. Please create the file first.")

# Main program
read_complaints()
