# Roll numbers of students present in Class A
classA = {1, 2, 3, 4, 5}

# Roll numbers of students present in Class B
classB = {3, 4, 5, 6, 7}

# Students present in both classes
both_classes = classA.intersection(classB)

print("Students present in both classes:", both_classes)
