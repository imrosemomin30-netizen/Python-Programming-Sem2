# Count frequency of items purched by customer
"""
Created on Mon Mar 16 15:34:28 2026

@author: imrose
"""

# List of items purchased by customers
items = ["Pen", "Notebook", "Pen", "Pencil", "Notebook", "Pen"]

# Dictionary to store frequency
frequency = {}

# Counting frequency
for item in items:
    if item in frequency:
        frequency[item] += 1
    else:
        frequency[item] = 1

# Display result
print("Item Purchase Frequency:")
for item, count in frequency.items():
    print(item, ":", count)
