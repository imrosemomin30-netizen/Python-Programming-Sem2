# A  school generates  multiplication tables for student from 1 to 10
"""
Created on Mon Mar  9 15:12:13 2026

@user:Imrose
"""


for i in range(1, 11):      # numbers from 1 to 10
    print("Table of", i)
    
    for j in range(1, 11):  # multiply from 1 to 10
        print(i, "x", j, "=", i*j)
    
    print()   # blank line after each table
    
    
