# Display today's date in a hospital appointment system
"""
Created on Mon Apr 20 21:34:34 2026

@author: imrose
"""

from datetime import date

# Get today's date
today = date.today()

# Display in hospital system format
print("===== Hospital Appointment System =====")
print("Today's Date:", today.strftime("%d-%m-%Y"))
print("Welcome! Please proceed to book your appointment.")
